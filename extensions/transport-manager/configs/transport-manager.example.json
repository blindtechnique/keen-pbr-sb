{
  "listen": "127.0.0.1:12122",
  "api_key": "REPLACE_WITH_A_LONG_RANDOM_VALUE",
  "sing_box_binary": "/opt/bin/sing-box",
  "runtime_dir": "/opt/var/run/keen-pbr/transports",
  "transports": [
    { "tag": "awg-primary", "type": "native", "interface": "nwg1" },
    {
      "tag": "proxy-backup",
