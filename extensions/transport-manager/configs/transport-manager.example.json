      "interface": "tun-proxy",
      "auto_start": false,
      "link": "vless://UUID@example.com:443?security=reality&sni=www.example.com&fp=chrome&pbk=PUBLIC_KEY&sid=SHORT_ID&type=tcp",
      "mtu": 1420
    }
  ]
}
