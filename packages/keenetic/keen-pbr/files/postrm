#!/bin/sh

# opkg runs postrm for the previous package during an upgrade/reinstall too.
# Do not report a final removal while the replacement package is being installed.
[ "${PKG_UPGRADE:-0}" = "1" ] && exit 0

cat <<'EOF'
keen-pbr has been removed.
dnsmasq fallback config from keen-pbr is no longer available.
If upstream DNS servers are not configured in your system dnsmasq settings,
internet access may stop working.
Configure upstream DNS servers manually if they are not set yet.

Hint: add "server=8.8.8.8" (or other DNS servers) to the /opt/etc/dnsmasq.conf file.
EOF

exit 0
