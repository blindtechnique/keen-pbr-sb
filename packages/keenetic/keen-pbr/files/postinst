#!/bin/sh

DNSMASQ_CONF="/opt/etc/dnsmasq.conf"
DNSMASQ_TEMPLATE="/opt/usr/lib/keen-pbr/dnsmasq.conf.template"
DNSMASQ_BACKUP="/opt/etc/dnsmasq.conf.backup-pre-keen-pbr"

echo "keen-pbr installation"
echo "------------------------"

mkdir -p /opt/usr/lib/keen-pbr

answer=""
if [ -f "$DNSMASQ_TEMPLATE" ]; then
    if [ -n "${KEEN_PBR_REPLACE_DNSMASQ_DEFAULTS:-}" ]; then
        answer="$KEEN_PBR_REPLACE_DNSMASQ_DEFAULTS"
    elif [ -t 0 ] && [ -t 1 ]; then
        echo "Tip: set KEEN_PBR_REPLACE_DNSMASQ_DEFAULTS=Y or N to automate keen-pbr installation."
        while :; do
            printf "Replace %s with recommended keen-pbr dnsmasq defaults? [y/n]: " "$DNSMASQ_CONF"
            read answer || answer=""
            case "$answer" in
                y|Y|n|N)
                    break
                    ;;
                *)
                    echo "Please enter Y or N."
                    ;;
            esac
        done
    else
        echo "Tip: set KEEN_PBR_REPLACE_DNSMASQ_DEFAULTS=Y or N to automate keen-pbr installation."
    fi
fi

case "$answer" in
    y|Y)
        if [ -f "$DNSMASQ_CONF" ]; then
            printf "Backing up existing %s to %s\n" "$DNSMASQ_CONF" "$DNSMASQ_BACKUP"
            cp "$DNSMASQ_CONF" "$DNSMASQ_BACKUP"
        fi
        printf "Installing recommended keen-pbr dnsmasq base config to %s\n" "$DNSMASQ_CONF"
        cp "$DNSMASQ_TEMPLATE" "$DNSMASQ_CONF"
        ;;
    n|N)
        echo "Keeping existing dnsmasq base config unchanged."
        ;;
    "")
        ;;
    *)
        printf "Ignoring invalid KEEN_PBR_REPLACE_DNSMASQ_DEFAULTS value: %s. Use Y or N.\n" "$answer"
        ;;
esac

echo ""
TRANSPORT_CONFIG="/opt/etc/keen-pbr/transports.json"
if [ -f "$TRANSPORT_CONFIG" ] && grep -q 'REPLACE_WITH_A_LONG_RANDOM_VALUE' "$TRANSPORT_CONFIG"; then
    # BusyBox od on Entware does not support the GNU -A option.  Hashing
    # random bytes gives us a portable, fixed-width 64-character key.
    transport_api_key="$(head -c 64 /dev/urandom | sha256sum | cut -d ' ' -f1)"
    sed -i "s/REPLACE_WITH_A_LONG_RANDOM_VALUE/$transport_api_key/" "$TRANSPORT_CONFIG"
fi
chmod 600 "$TRANSPORT_CONFIG" 2>/dev/null || true

# Older keen-pbr-sb builds could atomically replace nfqws2 files with mode
# 0600. nfqws2 drops privileges to nobody, so repair read/traverse access on
# upgrade without changing file contents.
if [ -d /opt/etc/nfqws2 ]; then
    chmod 0755 /opt/etc/nfqws2 2>/dev/null || true
    for directory in /opt/etc/nfqws2/lists /opt/etc/nfqws2/lua; do
        [ -d "$directory" ] || continue
        chmod 0755 "$directory" 2>/dev/null || true
        find "$directory" -type f \( -name '*.list' -o -name '*.lua' \) \
            -exec chmod 0644 {} \; 2>/dev/null || true
    done
    chmod 0644 /opt/etc/nfqws2/nfqws2.conf 2>/dev/null || true
fi
if ! /opt/etc/init.d/S79transport-manager start; then
    echo "Failed to start transport-manager service" >&2
    exit 1
fi
if ! /opt/etc/init.d/S80keen-pbr start; then
    echo "Failed to start keen-pbr service" >&2
    exit 1
fi
echo ""

echo "Installation complete!"
echo "Config path: /opt/etc/keen-pbr/config.json"
echo "Web API: http://my.keenetic.net:12121"

exit 0
